# Test Environment Variables
# Copy this file to .env.test and fill in the values

# Test Admin Credentials
TEST_ADMIN_EMAIL=test-admin@adtool-ai-test.internal
TEST_ADMIN_PASSWORD=your-secure-test-admin-password-here

# Test User Credentials
TEST_USER_EMAIL=test-user@adtool-ai-test.internal
TEST_USER_PASSWORD=your-secure-test-user-password-here

# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Percy for Visual Regression
# PERCY_TOKEN=your-percy-token-here

# Optional: k6 Cloud for Load Tests
# K6_CLOUD_TOKEN=your-k6-cloud-token-here
